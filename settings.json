      "Write(~/.claude/**)",
      "Edit(~/.claude/**)",
      "Write(~/.claude/context/**)",
      "Edit(~/.claude/context/**)",
      "Write(~/.claude/output/**)",
      "Edit(~/.claude/output/**)",
      "Write(~/.claude/agents/**)",
      "Edit(~/.claude/agents/**)",
      "Write(C:/Users/hara/.claude/**)",
      "Edit(C:/Users/hara/.claude/**)",
      "Write(C:/Users/hara/.claude/context/**)",
      "Edit(C:/Users/hara/.claude/context/**)",
      "Write(C:/Users/hara/.claude/output/**)",
      "Edit(C:/Users/hara/.claude/output/**)",
      "Write(C:/Users/hara/.claude/agents/**)",
      "Edit(C:/Users/hara/.claude/agents/**)",
